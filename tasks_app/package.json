{
  "name": "taskflow-tests",
  "version": "1.0.0",
  "description": "TaskFlow Widget Tests",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/core/filters/**/*.test.js"],
    "verbose": true,
    "collectCoverageFrom": ["core/filters/**/*.js"],
    "setupFilesAfterEnv": ["<rootDir>/core/filters/jest.setup.js"]
  }
}
